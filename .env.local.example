# ==========================================
# B2C JERSEY STORE - ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# Copy this file to '.env.local' and substitute the placeholders with your actual keys.
# NEVER commit the '.env.local' file containing real secrets to git.

# ------------------------------------------
# Supabase Configuration
# ------------------------------------------
# Your Supabase Project URL (e.g. https://xxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Supabase Anonymous Public API Key (safe to expose in client-side code)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Server-Only Service Role Key (bypasses RLS - NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------
# Cloudinary Configuration (Unsigned presets for admin media uploads)
# ------------------------------------------
# Cloudinary Cloud Name (identifies your Cloudinary account)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name

# Cloudinary API Public Key
CLOUDINARY_API_KEY=your-cloudinary-api-key

# Cloudinary API Secret Key (server-only)
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Unsigned upload preset name configured in Cloudinary Settings -> Upload presets
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-cloudinary-unsigned-upload-preset

# ------------------------------------------
# Razorpay Configuration (Payments Gateway)
# ------------------------------------------
# Razorpay Public API Key ID (e.g., rzp_test_xxxxxx)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id

# Razorpay Secret Key (server-only - e.g., xxxxxx)
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ------------------------------------------
# Store Customization & Admin Portal Settings
# ------------------------------------------
# The passcode used to access the protected admin portal at '/admin'
ADMIN_PASSWORD=your-secure-admin-passcode

# Display name of your jersey e-commerce store
NEXT_PUBLIC_STORE_NAME=JerseyStore
